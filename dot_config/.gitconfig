[user]
	name = thomas0124
	email = qingshuitouzhen@gmail.com
[init]
    defaultBranch = main
[push]
        default = current
[fetch]
        prune = true
[status]
        showUntrackedFiles = all
[core]
        autocrlf = input
        ignorecase = false
        quotepath = false
        precomposeunicode = true
	excludesfile = /Users/shimizutoorushin/.config/git/ignore
[color]
        ui = true
        diff = auto
        status = auto
        branch = auto
[merge]
        conflictStyle = diff3
[url "git@github.com:"]
	insteadOf = https://github.com/

[url "https://github.com/zsh-users/"]
        insteadOf = https://github.com/zsh-users/

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
